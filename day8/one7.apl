instrs ← ('□' 3 2) ('↕' 2 1) ('↔' 1 4) ('↕' 2 1)

grid ← 3 7 ⍴ 0

apply ← {
    (⊃⍺) ≡ '□' : ⍺ {_ w h ← ⍺ ⋄ ⍵[⍳h; ⍳w] ← 1 ⋄ ⍵} ⍵ ⋄
    (⊃⍺) ≡ '↕' : ⍺ {_ x mag ← ⍺ ⋄ ⍵[;x] ← (-mag) ⊖ ⍵[;x] ⋄ ⍵} ⍵ ⋄
    (⊃⍺) ≡ '↔' : ⍺ {_ y mag ← ⍺ ⋄ ⍵[y;] ← (-mag) ⌽ ⍵[y;] ⋄ ⍵} ⍵ ⋄
}

⎕ ← +/ +/ ⊃ apply/ ⌽ grid , instrs
